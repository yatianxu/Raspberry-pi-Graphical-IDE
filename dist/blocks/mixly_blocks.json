{
  "name": "RobEx教育机器人",
  "description": "RobEx教育机器人图形化编程块定义",
  "version": "2.1.0",
  "categories": [
    {
      "name": "系统",
      "color": "#5C81A6",
      "blocks": [
        {
          "type": "robex_init",
          "message": "初始化RobEx",
          "code": "robex.init()"
        },
        {
          "type": "robex_get_info",
          "message": "板载信息",
          "output": "dict",
          "code": "robex.get_board_capabilities()"
        },
        {
          "type": "time_sleep",
          "message": "延时 %1 秒",
          "args": [
            { "type": "input_value", "name": "SEC", "check": "Number" }
          ],
          "code": "time.sleep(%SEC%)"
        },
        {
          "type": "time_sleep_ms",
          "message": "延时 %1 毫秒",
          "args": [
            { "type": "input_value", "name": "MS", "check": "Number" }
          ],
          "code": "time.sleep_ms(int(%MS%))"
        }
      ]
    },
    {
      "name": "舵机",
      "color": "#5CA65C",
      "blocks": [
        {
          "type": "servo_init",
          "message": "舵机 %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "CH",
              "options": [
                ["S0", "0"],
                ["S1", "1"],
                ["S2", "2"],
                ["S3", "3"]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Servo(%CH%)"
        },
        {
          "type": "servo_init_mode",
          "message": "舵机 %1 模式 %2",
          "args": [
            {
              "type": "field_dropdown",
              "name": "CH",
              "options": [
                ["S0", "0"],
                ["S1", "1"],
                ["S2", "2"],
                ["S3", "3"]
              ]
            },
            {
              "type": "field_dropdown",
              "name": "MODE",
              "options": [
                ["角度180", "angle180"],
                ["角度360", "angle360"],
                ["连续", "continuous"]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Servo(%CH%, mode=\"%MODE%\")"
        },
        {
          "type": "servo_set_angle",
          "message": "设置舵机 %1 角度 %2",
          "args": [
            { "type": "input_value", "name": "SERVO", "check": "Object" },
            { "type": "input_value", "name": "ANGLE", "check": "Number" }
          ],
          "code": "%SERVO%.angle(%ANGLE%)"
        },
        {
          "type": "servo_set_speed",
          "message": "连续舵机 %1 速度 %2",
          "args": [
            { "type": "input_value", "name": "SERVO", "check": "Object" },
            { "type": "input_value", "name": "SPEED", "check": "Number" }
          ],
          "code": "%SERVO%.speed(%SPEED%)"
        },
        {
          "type": "servo_set_mode",
          "message": "舵机 %1 模式 %2",
          "args": [
            { "type": "input_value", "name": "SERVO", "check": "Object" },
            {
              "type": "field_dropdown",
              "name": "MODE",
              "options": [
                ["角度180", "angle180"],
                ["角度360", "angle360"]
              ]
            }
          ],
          "code": "%SERVO%.set_mode(\"%MODE%\")"
        },
        {
          "type": "servo_read",
          "message": "舵机 %1 角度",
          "args": [{ "type": "input_value", "name": "SERVO", "check": "Object" }],
          "output": "Number",
          "code": "%SERVO%.angle()"
        },
        {
          "type": "servo_release",
          "message": "舵机 %1 释放",
          "args": [{ "type": "input_value", "name": "SERVO", "check": "Object" }],
          "code": "%SERVO%.release()"
        }
      ]
    },
    {
      "name": "电机",
      "color": "#5C68A6",
      "blocks": [
        {
          "type": "motor_init",
          "message": "电机 %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "CH",
              "options": [
                ["M0", "0"],
                ["M1", "1"],
                ["M2", "2"],
                ["M3", "3"]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Motor(%CH%)"
        },
        {
          "type": "motor_duty",
          "message": "设置电机 %1 占空比(%) %2 方向 %3",
          "args": [
            { "type": "input_value", "name": "MOTOR", "check": "Object" },
            { "type": "input_value", "name": "SPEED", "check": "Number" },
            {
              "type": "field_dropdown",
              "name": "DIR",
              "options": [
                ["正转", "1"],
                ["反转", "-1"]
              ]
            }
          ],
          "code": "%MOTOR%.duty(int((%SPEED% * %DIR%) * 10))"
        },
        {
          "type": "motor_velocity",
          "message": "设置电机 %1 转速 %2 方向 %3",
          "args": [
            { "type": "input_value", "name": "MOTOR", "check": "Object" },
            { "type": "input_value", "name": "RPM", "check": "Number" },
            {
              "type": "field_dropdown",
              "name": "DIR",
              "options": [
                ["正转", "1"],
                ["反转", "-1"]
              ]
            }
          ],
          "code": "%MOTOR%.velocity(%RPM% * %DIR%)"
        },
        {
          "type": "motor_position",
          "message": "设置电机 %1 位置 %2 限速 %3",
          "args": [
            { "type": "input_value", "name": "MOTOR", "check": "Object" },
            { "type": "input_value", "name": "POS", "check": "Number" },
            { "type": "input_value", "name": "SPEED", "check": "Number" }
          ],
          "code": "%MOTOR%.position(%POS%, speed=int(%SPEED% * 10))"
        },
        {
          "type": "motor_config_pid",
          "message": "设置电机 %1 PID P%2 I%3 D%4",
          "args": [
            { "type": "input_value", "name": "MOTOR", "check": "Object" },
            { "type": "input_value", "name": "KP", "check": "Number" },
            { "type": "input_value", "name": "KI", "check": "Number" },
            { "type": "input_value", "name": "KD", "check": "Number" }
          ],
          "code": "%MOTOR%.config_pid(%KP%, %KI%, %KD%)"
        },
        {
          "type": "motor_stop",
          "message": "电机 %1 停止(滑行)",
          "args": [{ "type": "input_value", "name": "MOTOR", "check": "Object" }],
          "code": "%MOTOR%.stop()"
        },
        {
          "type": "motor_brake",
          "message": "电机 %1 刹车",
          "args": [{ "type": "input_value", "name": "MOTOR", "check": "Object" }],
          "code": "%MOTOR%.brake()"
        }
      ]
    },
    {
      "name": "传感器",
      "color": "#A6745C",
      "blocks": [
        {
          "type": "robex_pin_init",
          "message": "初始化引脚 %1 模式 %2",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""], ["G1", "\"G1\""], ["G2", "\"G2\""], ["G3", "\"G3\""],
                ["G4", "\"G4\""], ["G5", "\"G5\""], ["G6", "\"G6\""], ["G7", "\"G7\""], ["G8", "\"G8\""],
                ["SW1", "\"SW1\""], ["SW2", "\"SW2\""], ["LED1", "\"LED1\""], ["LED2", "\"LED2\""]
              ]
            },
            {
              "type": "field_dropdown",
              "name": "MODE",
              "options": [
                ["输入", "robex.Pin.IN"],
                ["输出", "robex.Pin.OUT"]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Pin(%PIN%, %MODE%)"
        },
        {
          "type": "robex_adc_init",
          "message": "初始化ADC %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""], ["G1", "\"G1\""], ["G2", "\"G2\""], ["G3", "\"G3\""]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.ADC(%PIN%)"
        },
        {
          "type": "sensor_ultrasonic_init",
          "message": "超声波 %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""],
                ["G1", "\"G1\""],
                ["G2", "\"G2\""],
                ["G3", "\"G3\""],
                ["G4", "\"G4\""],
                ["G5", "\"G5\""],
                ["G6", "\"G6\""],
                ["G7", "\"G7\""],
                ["G8", "\"G8\""]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Ultrasonic(%PIN%)"
        },
        {
          "type": "sensor_ultrasonic_read",
          "message": "超声波 %1 距离",
          "args": [{ "type": "input_value", "name": "SENSOR", "check": "Object" }],
          "output": "Number",
          "code": "%SENSOR%.distance_cm()"
        },
        {
          "type": "sensor_pin_init",
          "message": "GPIO %1 %2",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""],
                ["G1", "\"G1\""],
                ["G2", "\"G2\""],
                ["G3", "\"G3\""],
                ["G4", "\"G4\""],
                ["G5", "\"G5\""],
                ["G6", "\"G6\""],
                ["G7", "\"G7\""],
                ["G8", "\"G8\""]
              ]
            },
            {
              "type": "field_dropdown",
              "name": "MODE",
              "options": [
                ["输入", "IN"],
                ["输出", "OUT"]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.Pin(%PIN%, robex.Pin.%MODE%)"
        },
        {
          "type": "sensor_pin_read",
          "message": "读 GPIO %1",
          "args": [{ "type": "input_value", "name": "PIN", "check": "Object" }],
          "output": "Number",
          "code": "%PIN%.value()"
        },
        {
          "type": "sensor_pin_write",
          "message": "写 GPIO %1 值 %2",
          "args": [
            { "type": "input_value", "name": "PIN", "check": "Object" },
            {
              "type": "field_dropdown",
              "name": "VAL",
              "options": [
                ["低", "0"],
                ["高", "1"]
              ]
            }
          ],
          "code": "%PIN%.value(%VAL%)"
        },
        {
          "type": "sensor_pwm_init",
          "message": "PWM %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""],
                ["G1", "\"G1\""],
                ["G2", "\"G2\""],
                ["G3", "\"G3\""],
                ["G4", "\"G4\""],
                ["G5", "\"G5\""],
                ["G6", "\"G6\""],
                ["G7", "\"G7\""],
                ["G8", "\"G8\""]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.PWM(%PIN%)"
        },
        {
          "type": "sensor_pwm_set",
          "message": "设置 PWM %1 占空比(%) %2",
          "args": [
            { "type": "input_value", "name": "PWM", "check": "Object" },
            { "type": "input_value", "name": "DUTY", "check": "Number" }
          ],
          "code": "%PWM%.duty(%DUTY%)"
        },
        {
          "type": "sensor_pwm_deinit",
          "message": "PWM %1 停止",
          "args": [{ "type": "input_value", "name": "PWM", "check": "Object" }],
          "code": "%PWM%.deinit()"
        },
        {
          "type": "sensor_adc_init",
          "message": "ADC %1",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "\"G0\""],
                ["G1", "\"G1\""],
                ["G2", "\"G2\""],
                ["G3", "\"G3\""]
              ]
            }
          ],
          "output": "Object",
          "code": "robex.ADC(%PIN%)"
        },
        {
          "type": "sensor_adc_read",
          "message": "读 ADC %1",
          "args": [{ "type": "input_value", "name": "ADC", "check": "Object" }],
          "output": "Number",
          "code": "%ADC%.read()"
        }
      ]
    },
    {
      "name": "LED灯带",
      "color": "#A65C81",
      "blocks": [
        {
          "type": "led_strip_create",
          "message": "创建LED灯带 %1 数量 %2",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "0"],
                ["G1", "1"],
                ["G2", "2"],
                ["G3", "3"],
                ["G4", "4"],
                ["G5", "5"],
                ["G6", "6"],
                ["G7", "7"],
                ["G8", "8"]
              ]
            },
            { "type": "input_value", "name": "COUNT", "check": "Number" }
          ],
          "output": "Object",
          "code": "robex.NeoPixel(%PIN%, %COUNT%)"
        },
        {
          "type": "led_color_rgb",
          "message": "颜色 R %1 G %2 B %3",
          "args": [
            { "type": "input_value", "name": "R", "check": "Number" },
            { "type": "input_value", "name": "G", "check": "Number" },
            { "type": "input_value", "name": "B", "check": "Number" }
          ],
          "output": "Array",
          "code": "(%R%, %G%, %B%)"
        },
        {
          "type": "led_color_picker",
          "message": "颜色 %1",
          "args": [
            { "type": "field_colour", "name": "COLOR", "colour": "#ff0000" }
          ],
          "output": "Array",
          "code": "(int(%COLOR%[1:3],16), int(%COLOR%[3:5],16), int(%COLOR%[5:7],16))"
        },
        {
          "type": "led_set_pixel_obj",
          "message": "LED灯带 %1 设置第 %2 个灯 颜色 %3",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "INDEX", "check": "Number" },
            { "type": "input_value", "name": "COLOR", "check": "Array" }
          ],
          "code": "%STRIP%.set_pixel(%INDEX%, *%COLOR%)"
        },
        {
          "type": "led_set_range",
          "message": "LED灯带 %1 设置从 %2 到 %3 颜色 %4",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "START", "check": "Number" },
            { "type": "input_value", "name": "END", "check": "Number" },
            { "type": "input_value", "name": "COLOR", "check": "Array" }
          ],
          "code": "%STRIP%.set_range(%START%, %END%, *%COLOR%)"
        },
        {
          "type": "led_set_all",
          "message": "LED灯带 %1 设置全部 颜色 %2",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "COLOR", "check": "Array" }
          ],
          "code": "%STRIP%.set_all(*%COLOR%)"
        },
        {
          "type": "led_off_pixel",
          "message": "LED灯带 %1 熄灭第 %2 个灯",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "INDEX", "check": "Number" }
          ],
          "code": "%STRIP%.off_pixel(%INDEX%)"
        },
        {
          "type": "led_off_range",
          "message": "LED灯带 %1 熄灭从 %2 到 %3",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "START", "check": "Number" },
            { "type": "input_value", "name": "END", "check": "Number" }
          ],
          "code": "%STRIP%.off_range(%START%, %END%)"
        },
        {
          "type": "led_clear",
          "message": "LED灯带 %1 全部熄灭",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" }
          ],
          "code": "%STRIP%.clear()"
        },
        {
          "type": "led_show_obj",
          "message": "LED灯带 %1 刷新显示",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" }
          ],
          "code": "%STRIP%.show()"
        },
        {
          "type": "led_rainbow",
          "message": "LED灯带 %1 显示彩虹 偏移 %2",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "OFFSET", "check": "Number" }
          ],
          "code": "%STRIP%.rainbow(%OFFSET%)"
        },
        {
          "type": "led_breathing",
          "message": "LED灯带 %1 呼吸灯效果 颜色 %2 速度 %3 循环次数 %4",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "COLOR", "check": "Array" },
            { "type": "input_value", "name": "SPEED", "check": "Number" },
            { "type": "input_value", "name": "CYCLES", "check": "Number" }
          ],
          "code": "%STRIP%.breathing(%COLOR%, %SPEED%, %CYCLES%)"
        },
        {
          "type": "led_chase",
          "message": "LED灯带 %1 跑马灯效果 颜色 %2 速度 %3 圈数 %4",
          "args": [
            { "type": "input_value", "name": "STRIP", "check": "Object" },
            { "type": "input_value", "name": "COLOR", "check": "Array" },
            { "type": "input_value", "name": "SPEED", "check": "Number" },
            { "type": "input_value", "name": "ROUNDS", "check": "Number" }
          ],
          "code": "%STRIP%.chase(%COLOR%, %SPEED%, %ROUNDS%)"
        },
        {
          "type": "led_init",
          "message": "初始化LED灯带(全局) %1 数量 %2",
          "args": [
            {
              "type": "field_dropdown",
              "name": "PIN",
              "options": [
                ["G0", "0"],
                ["G1", "1"],
                ["G2", "2"],
                ["G3", "3"],
                ["G4", "4"],
                ["G5", "5"],
                ["G6", "6"],
                ["G7", "7"],
                ["G8", "8"]
              ]
            },
            { "type": "input_value", "name": "COUNT", "check": "Number" }
          ],
          "code": "robex.led.init(%PIN%, %COUNT%)"
        },
        {
          "type": "led_set_pixel",
          "message": "设置LED(全局) 第 %1 个灯 颜色 %2",
          "args": [
            { "type": "input_value", "name": "INDEX", "check": "Number" },
            { "type": "input_value", "name": "COLOR", "check": "Array" }
          ],
          "code": "robex.led.set_pixel(%INDEX%, *%COLOR%)"
        },
        {
          "type": "led_set_all_global",
          "message": "设置全部LED(全局) 颜色 %1",
          "args": [
            { "type": "input_value", "name": "COLOR", "check": "Array" }
          ],
          "code": "robex.led.set_all(*%COLOR%)"
        },
        {
          "type": "led_show",
          "message": "刷新LED显示(全局)",
          "code": "robex.led.show()"
        },
        {
          "type": "led_clear_global",
          "message": "清除所有LED(全局)",
          "code": "robex.led.clear()"
        },
        {
          "type": "led_set_pixel_oldstyle",
          "message": "LED %1 颜色 %2",
          "args": [
            { "type": "input_value", "name": "INDEX", "check": "Number" },
            { "type": "field_colour", "name": "COLOR", "colour": "#ff0000" }
          ],
          "code": "robex.led.set_pixel(%INDEX%, int(%COLOR%[1:3],16), int(%COLOR%[3:5],16), int(%COLOR%[5:7],16))"
        }
      ]
    },
    {
      "name": "相机/屏幕",
      "color": "#81A65C",
      "blocks": [
        {
          "type": "maix_camera_init",
          "message": "摄像头 %1×%2 %3 %4fps",
          "args": [
            { "type": "field_number", "name": "WIDTH", "value": 552, "min": 1, "max": 4096, "precision": 1 },
            { "type": "field_number", "name": "HEIGHT", "value": 368, "min": 1, "max": 4096, "precision": 1 },
            {
              "type": "field_dropdown",
              "name": "FORMAT",
              "options": [
                ["RGB888", "FMT_RGB888"],
                ["RGB565", "FMT_RGB565"],
                ["灰度", "FMT_GRAYSCALE"]
              ]
            },
            { "type": "field_number", "name": "FPS", "value": 30, "min": 1, "max": 120, "precision": 1 }
          ],
          "output": "Object",
          "code": "camera.Camera(width=%WIDTH%, height=%HEIGHT%, format=image.Format.%FORMAT%, fps=%FPS%)"
        },
        {
          "type": "maix_display_init",
          "message": "显示屏",
          "output": "Object",
          "code": "display.Display()"
        },
        {
          "type": "maix_camera_read",
          "message": "摄像头 %1 读帧",
          "args": [{ "type": "input_value", "name": "CAM", "check": "Object" }],
          "output": "Object",
          "code": "%CAM%.read()"
        },
        {
          "type": "maix_display_show",
          "message": "显示图像 %1",
          "args": [
            { "type": "input_value", "name": "IMG", "check": "Object" }
          ],
          "code": "display.Display().show(%IMG%)"
        }
      ]
    },
    {
      "name": "AI视觉",
      "color": "#7C3AED",
      "blocks": [
        {
          "type": "robex_vision_camera_open",
          "message": "打开摄像头并同步到屏幕",
          "code": "robex.vision.open_camera()"
        },
        {
          "type": "robex_vision_camera_close",
          "message": "关闭摄像头(强制)",
          "code": "robex.vision.close_camera()"
        },
        {
          "type": "robex_vision_read_qr",

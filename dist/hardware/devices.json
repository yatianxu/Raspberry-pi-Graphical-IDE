{
  "version": "1.0",
  "devices": [
    {
      "id": "button",
      "name": "按键",
      "desc": "板载按键",
      "interfaceType": "button",
      "initCode": "robex.Pin(%PIN%, robex.Pin.IN)"
    },
    {
      "id": "led",
      "name": "LED",
      "desc": "板载LED指示灯",
      "interfaceType": "led",
      "initCode": "robex.Pin(%PIN%, robex.Pin.OUT)"
    },
    {
      "id": "adc_sensor",
      "name": "ADC传感器",
      "desc": "模拟量输入传感器",
      "interfaceType": "adc",
      "initCode": "robex.ADC(%PIN%)"
    },
    {
      "id": "digital_sensor",
      "name": "数字传感器",
      "desc": "GPIO 输入",
      "interfaceType": "gpio_in",
      "initCode": "robex.Pin(%PIN%, robex.Pin.IN)"
    },
    {
      "id": "digital_output",
      "name": "数字输出模块",
      "desc": "GPIO 输出",
      "interfaceType": "gpio_out",
      "initCode": "robex.Pin(%PIN%, robex.Pin.OUT)"
    },
    {
      "id": "line_sensor_5ch",
      "name": "5路循迹传感器",
      "desc": "连接 T0~T4 的单一模块",
      "interfaceType": "ir_array",
      "initCode": "robex.IRArray([\"T0\",\"T1\",\"T2\",\"T3\",\"T4\"])"
    },
    {
      "id": "i2c_device",
      "name": "I2C设备",
      "desc": "I2C 扩展设备（需配置初始化代码）",
      "interfaceType": "i2c"
    },
    {
      "id": "uart_device",
      "name": "UART设备",
      "desc": "UART 扩展设备（需配置初始化代码）",
      "interfaceType": "uart"
    },
    {
      "id": "servo",
      "name": "伺服电机",
      "desc": "舵机接口",
      "interfaceType": "servo",
      "initCode": "robex.Servo(%CH%)"
    },
    {
      "id": "motor",
      "name": "编码电机",
      "desc": "编码电机接口",
      "interfaceType": "motor",
      "initCode": "robex.Motor(%CH%)"
    }
  ]
}
